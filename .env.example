APP_ENV=local
LOG_LEVEL=INFO

# Database
POSTGRES_DB=financial_agent
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me-in-local
DATABASE_URL=postgresql+asyncpg://app:change-me-in-local@postgres:5432/financial_agent

# Cache
REDIS_URL=redis://redis:6379/0

# Auth
JWT_SECRET_KEY=change-me-in-local
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# LLM
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
HF_TOKEN=

# Service URLs for Docker Compose network
BACKEND_BASE_URL=http://backend-gateway:8000
AGENT_SERVICE_URL=http://agent-service:8001
MOCK_FINANCIAL_SERVICE_URL=http://mock-financial-service:8002

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Observability and alerting
DISCORD_ALERT_ENABLED=false
DISCORD_WEBHOOK_URL=
METRICS_ENABLED=false
