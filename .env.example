APP_ENV=local
LOG_LEVEL=INFO

# Database - local Docker Compose
POSTGRES_DB=financial_agent
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me-in-local
DATABASE_URL=postgresql://myuser:mypassword@localhost:5432/financial_agent

# REDIS
REDIS_CACHE_URL=redis://localhost:6379/0
REDIS_STREAM_URL=redis://localhost:6380/0

# Database - deployed environments
# Prefer split DB_* values when the app supports them, so DB_PASSWORD can come from a secret manager.
DB_HOST=myuser
DB_PORT=5432
DB_NAME=financial_agent
DB_USER=myuser
DB_PASSWORD=mypassword

# Auth
JWT_SECRET_KEY=change-me-in-local
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# SSE
SSE_TICKET_TTL_SECONDS=120

# Agent Stream (Redis Streams 브릿지)
AGENT_STREAM_BLOCK_MS=15000
AGENT_STREAM_MAXLEN=1000
AGENT_STREAM_TTL_SECONDS=3600
AGENT_WEBHOOK_SECRET=change-me-agent-webhook
SSE_TICKET_RATE_LIMIT=30/minute
SSE_CONNECT_RATE_LIMIT=60/minute

# LLM
# 제공자 선택: openai(기본, OPENAI_API_KEY 필요) | vertex(Google Cloud Vertex AI) | ollama
LLM_PROVIDER=openai
# 모델 (미지정 시 제공자별 기본값: openai=gpt-4o-mini, vertex=gemini-2.5-flash, ollama=qwen2.5:3b)
LLM_MODEL=
OPENAI_API_KEY=
HF_TOKEN=

# Ollama (LLM_PROVIDER=ollama일 때)
# 로컬 실행: http://localhost:11434
# Docker 컨테이너에서 호스트 Ollama 접근(Mac/Windows): http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# Vertex AI (LLM_PROVIDER=vertex일 때)
# 인증: 로컬은 `gcloud auth application-default login`(ADC),
#       컨테이너는 서비스 계정 JSON을 마운트하고 GOOGLE_APPLICATION_CREDENTIALS 지정
GOOGLE_CLOUD_PROJECT=
VERTEX_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Agent bank data access: local(인메모리 mock) | http(mock-financial-service)
# docker compose는 agent 서비스에서 http로 오버라이드한다
BANK_CLIENT=local

# Backend Gateway -> mock-financial-service(계정계/정보계) 접근: mock(내장 픽스처) | http(실서비스)
# docker compose는 backend 서비스에서 http로 오버라이드한다
FINANCIAL_CLIENT=mock
# 정보계(analytics) 읽기 API 키 — mock-financial-service analytics_router의 데모 상수와 일치해야 한다
FINANCIAL_ANALYTICS_KEY=analytics-demo-key
# Phase 1 데모 시드 매핑: User<->account_id 프로비저닝(Phase 2) 전까지 fallback account_id. 비우면 미사용
FINANCIAL_DEMO_ACCOUNT_ID=
# Phase 2 데모 송금 수취처(계좌번호+은행명 기반). 둘 다 비우면 승인 시 실이체를 건너뛴다(챗 메시지만)
FINANCIAL_DEMO_RECEIVER_BANK_NAME=
FINANCIAL_DEMO_RECEIVER_ACCOUNT_NUMBER=

# Service URLs for Docker Compose network
BACKEND_BASE_URL=http://backend-gateway:8000
AGENT_SERVICE_URL=http://agent-service:8001
MOCK_FINANCIAL_SERVICE_URL=http://mock-financial-service:8002

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Observability and alerting
DISCORD_ALERT_ENABLED=false
DISCORD_WEBHOOK_URL=
METRICS_ENABLED=false
